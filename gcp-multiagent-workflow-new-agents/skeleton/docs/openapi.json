{
  "openapi": "3.1.0",
  "info": {
    "title": "GCP Agent API",
    "description": "GCP Cloud run with FastAPI for GCP Agent conversations",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "${{ values.data_openapi_baseurl }}"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health Check",
        "description": "Health check endpoint",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
 
                }
              }
            }
          }
        }
      }
    },
    "/": {
      "get": {
        "summary": "Root",
        "description": "Root endpoint with API information",
        "operationId": "root__get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
 
                }
              }
            }
          }
        }
      }
    },
    "/invoke-agent": {
      "post": {
        "tags": [
          "vertexai"
        ],
        "summary": "Invoke Agent Endpoint",
        "description": "Invoke the multi-agent system with user input",
        "operationId": "invoke_agent_endpoint_invoke_agent_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StreamQueryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StreamQueryResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StreamQueryRequest": {
        "properties": {
          "userInput": {
            "type": "string",
            "title": "Userinput"
          },
          "userId": {
            "type": "string",
            "title": "UserId"
          },
          "sessionId": {
            "type": "string",
            "title": "SessionId"
          },
          "agentId": {
            "type": "string",
            "title": "Agentid"
          },
          "agentDisplayName": {
            "type": "string",
            "title": "AgentDisplayName"
          },
          "agentVersion": {
            "type": "string",
            "title": "AgentVersion"
          }
        },
        "type": "object",
        "required": [
          "userInput",
          "agentId",
          "agentDisplayName",
          "agentVersion"
        ],
        "title": "AgentRequest"
      },
      "StreamQueryResponse": {
        "properties": {
          "response": {
            "type": "string",
            "title": "Response"
          },
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "response",
          "status"
        ],
        "title": "AgentResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}