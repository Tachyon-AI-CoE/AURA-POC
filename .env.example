# AURA-POC — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ---- GitHub App auth ----
GITHUB_APP_ID=your-github-app-id
GITHUB_INSTALLATION_ID=your-github-installation-id
GITHUB_ORG=your-github-org
GENERATED_AGENTS_REPO=your-generated-components-repo

# Provide ONE of the following (precedence: PRIVATE_KEY -> PRIVATE_KEY_FILE -> GCP Secret Manager):
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_FILE=
# GCP Secret Manager fallback (used on Cloud Run automatically):
GCP_PROJECT_ID=your-gcp-project-id
GITHUB_PRIVATE_KEY_SECRET=your-secret-manager-name

# ---- API auth ----
# Bearer token required by POST /scaffold (FR-4). Generate with `openssl rand -hex 32`.
SCAFFOLD_API_KEY=generate-with-openssl-rand-hex-32

# ---- CORS ----
# Comma-separated list of allowed origins. Empty = deny all (NFR-8).
CORS_ALLOWLIST=

# ---- Transitional ----
# Path to a fallback agent_input.json file used when POST /scaffold body is empty (FR-11).
AGENT_INPUT_PATH=./inputs/agent_input.json

# ---- Logging ----
LOG_LEVEL=INFO
